<div id="upload-modal" class="hiddens fixed inset-0 z-50 flex items-center justify-center p-4">
    <div class="absolute inset-0 dark:bg-black/70 bg-black/40 backdrop-blur-sm" onclick="closeUploadModal()"></div>

    <div
        class="relative w-full max-w-xl dark:bg-obsidian-950 bg-white rounded-2xl border dark:border-stone-800 border-stone-200 shadow-2xl overflow-hidden">

        <!-- Header -->
        <div class="flex items-center justify-between px-6 pt-6 pb-4 border-b dark:border-stone-800 border-stone-100">
            <div>
                <h2 class="font-display font-bold text-lg dark:text-white text-stone-900">Upload Files</h2>
                <p class="font-mono text-[11px] dark:text-stone-500 text-stone-400 mt-0.5">Max 10 files · 5 MB each</p>
            </div>
            <button onclick="closeUploadModal()"
                class="p-1.5 rounded-lg dark:hover:bg-stone-800 hover:bg-stone-100 dark:text-stone-500 text-stone-400 transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
        </div>

        <form id="upload-form" action="/upload" method="POST" enctype="multipart/form-data">
            <div class="px-6 py-5 space-y-5 max-h-[75vh] overflow-y-auto">

                <!-- ── Drop Zone ── -->
                <div>
                    <div id="drop-zone" class="relative rounded-xl p-8 text-center cursor-pointer
              border-2 border-dashed dark:border-stone-800 border-stone-200
              dark:bg-stone-900/40 bg-stone-50
              dark:hover:border-amber-500/60 hover:border-amber-500/60
              dark:hover:bg-amber-500/5 hover:bg-amber-500/5
              transition-all duration-200">

                        <!-- Icon -->
                        <div
                            class="w-12 h-12 rounded-xl bg-amber-500/15 border border-amber-500/25 flex items-center justify-center mx-auto mb-3">
                            <svg class="w-6 h-6 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
                            </svg>
                        </div>

                        <p class="font-display font-bold dark:text-stone-300 text-stone-600 mb-1">Drop files here</p>
                        <p class="font-mono text-xs dark:text-stone-600 text-stone-400 mb-3">or click to browse</p>

                        <!-- Accepted formats -->
                        <div class="flex flex-wrap justify-center gap-1.5">
                            {{#each acceptedFormats}}
                            <span
                                class="font-mono text-[10px] px-2 py-0.5 rounded-md dark:bg-stone-800 bg-stone-200 dark:text-stone-400 text-stone-500">
                                {{this}}
                            </span>
                            {{else}}
                            <span
                                class="font-mono text-[10px] px-2 py-0.5 rounded-md dark:bg-stone-800 bg-stone-200 dark:text-stone-400 text-stone-500">.png</span>
                            <span
                                class="font-mono text-[10px] px-2 py-0.5 rounded-md dark:bg-stone-800 bg-stone-200 dark:text-stone-400 text-stone-500">.jpg</span>
                            <span
                                class="font-mono text-[10px] px-2 py-0.5 rounded-md dark:bg-stone-800 bg-stone-200 dark:text-stone-400 text-stone-500">.jpeg</span>
                            <span
                                class="font-mono text-[10px] px-2 py-0.5 rounded-md dark:bg-stone-800 bg-stone-200 dark:text-stone-400 text-stone-500">.doc</span>
                            <span
                                class="font-mono text-[10px] px-2 py-0.5 rounded-md dark:bg-stone-800 bg-stone-200 dark:text-stone-400 text-stone-500">.docx</span>
                            <span
                                class="font-mono text-[10px] px-2 py-0.5 rounded-md dark:bg-stone-800 bg-stone-200 dark:text-stone-400 text-stone-500">.pdf</span>
                            <span
                                class="font-mono text-[10px] px-2 py-0.5 rounded-md dark:bg-stone-800 bg-stone-200 dark:text-stone-400 text-stone-500">.xls</span>
                            <span
                                class="font-mono text-[10px] px-2 py-0.5 rounded-md dark:bg-stone-800 bg-stone-200 dark:text-stone-400 text-stone-500">.zip</span>
                            {{/each}}
                        </div>

                        <input type="file" id="file-input" name="files" multiple
                            accept=".png,.jpg,.jpeg,.doc,.docx,.pdf,.xls,.zip" class="hidden" />
                    </div>

                    <!-- Validation error banner -->
                    <div id="upload-error"
                        class="hidden mt-3 flex items-start gap-2.5 px-4 py-3 rounded-xl bg-red-500/10 border border-red-500/25">
                        <svg class="w-4 h-4 text-red-400 shrink-0 mt-0.5" fill="none" stroke="currentColor"
                            viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        <div id="upload-error-text" class="font-mono text-xs text-red-400 leading-relaxed"></div>
                    </div>
                </div>

                <!-- ── File preview list ── -->
                <div id="file-preview" class="hidden space-y-2">
                    <div class="flex items-center justify-between mb-1">
                        <span
                            class="font-mono text-[11px] uppercase tracking-widest dark:text-stone-500 text-stone-400">
                            Selected — <span id="file-count">0</span> / 10
                        </span>
                        <button type="button" onclick="clearFiles()"
                            class="font-mono text-[11px] text-red-400 hover:text-red-300 transition-colors">
                            Clear all
                        </button>
                    </div>
                    <div id="file-list" class="space-y-1.5 max-h-44 overflow-y-auto pr-1"></div>
                </div>

                <!-- ── Folder path ── -->
                <div>
                    <label
                        class="block font-mono text-[11px] uppercase tracking-widest dark:text-stone-500 text-stone-400 mb-2">
                        Destination folder
                    </label>

                    <!-- Existing folders quick-pick -->
                    {{#if existingFolders.length}}
                    <div class="mb-2.5">
                        <p class="font-mono text-[10px] dark:text-stone-600 text-stone-400 mb-1.5">Quick select
                            existing:</p>
                        <div class="flex flex-wrap gap-1.5 max-h-24 overflow-y-auto">
                            {{#each existingFolders}}
                            <button type="button" onclick="selectFolder('{{this.path}}')" class="flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg font-mono text-[11px]
                  dark:bg-stone-900 bg-stone-100
                  dark:border-stone-800 border-stone-200 border
                  dark:text-stone-400 text-stone-600
                  dark:hover:border-amber-500/50 hover:border-amber-500/50
                  dark:hover:text-amber-400 hover:text-amber-500
                  transition-all duration-150">
                                <svg class="w-3 h-3 text-amber-500 shrink-0" fill="currentColor" viewBox="0 0 20 20">
                                    <path d="M2 6a2 2 0 012-2h5l2 2h5a2 2 0 012 2v6a2 2 0 01-2 2H4a2 2 0 01-2-2V6z" />
                                </svg>
                                {{this.path}}
                            </button>
                            {{/each}}
                        </div>
                    </div>
                    {{/if}}

                    <!-- Path input -->
                    <div class="relative">
                        <span class="absolute left-3.5 top-1/2 -translate-y-1/2 pointer-events-none">
                            <svg class="w-4 h-4 dark:text-stone-600 text-stone-400" fill="none" stroke="currentColor"
                                viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M3 7a2 2 0 012-2h4.586a1 1 0 01.707.293L12 7h7a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V7z" />
                            </svg>
                        </span>
                        <input type="text" id="folder-input" name="folder" placeholder="e.g. projects/documents" class="w-full pl-10 pr-4 py-3 rounded-xl text-sm font-mono
                dark:bg-stone-900 bg-stone-50
                dark:border-stone-800 border-stone-200 border
                dark:text-stone-200 text-stone-800
                dark:placeholder-stone-700 placeholder-stone-400
                focus:outline-none focus:border-amber-500 focus:ring-2 focus:ring-amber-500/20
                transition-all duration-200" />
                    </div>

                    <!-- Path preview breadcrumb -->
                    <div id="path-preview" class="hidden mt-2 flex items-center gap-1 flex-wrap"></div>

                    <p class="font-mono text-[11px] dark:text-stone-600 text-stone-400 mt-2">
                        Use <span class="dark:text-stone-400 text-stone-500">/</span> to create subfolders.
                        Leave empty to upload to root.
                    </p>
                </div>

            </div>

            <!-- Footer -->
            <div class="px-6 py-4 border-t dark:border-stone-800 border-stone-100 flex items-center gap-3">
                <button type="button" onclick="closeUploadModal()" class="flex-1 py-3 rounded-xl font-mono text-xs
            dark:bg-stone-900 bg-stone-100
            dark:border-stone-800 border-stone-200 border
            dark:text-stone-400 text-stone-600
            dark:hover:bg-stone-800 hover:bg-stone-200
            transition-all duration-150">
                    Cancel
                </button>
                <button type="submit" id="upload-submit" disabled class="flex-1 py-3 rounded-xl font-display font-bold text-sm
            bg-amber-500 text-obsidian-950
            disabled:opacity-40 disabled:cursor-not-allowed
            hover:bg-amber-400 active:scale-95
            shadow-lg shadow-amber-500/20
            transition-all duration-150">
                    Upload Files
                </button>
            </div>
        </form>
    </div>
</div>

<script>
    (function () {

        // ── Constants ──────────────────────────────────────────
        const MAX_FILES = 10;
        const MAX_SIZE_MB = 5;
        const MAX_SIZE_B = MAX_SIZE_MB * 1024 * 1024;
        const ACCEPTED_EXT = ['.png', '.jpg', '.jpeg', '.doc', '.docx', '.pdf', '.xls', '.zip'];

        let selectedFiles = [];

        // ── Elements ───────────────────────────────────────────
        const dropZone = document.getElementById('drop-zone');
        const fileInput = document.getElementById('file-input');
        const filePreview = document.getElementById('file-preview');
        const fileList = document.getElementById('file-list');
        const fileCount = document.getElementById('file-count');
        const submitBtn = document.getElementById('upload-submit');
        const folderInput = document.getElementById('folder-input');
        const pathPreview = document.getElementById('path-preview');
        const errorBox = document.getElementById('upload-error');
        const errorText = document.getElementById('upload-error-text');

        // ── Drop zone click ─────────────────────────────────────
        dropZone.addEventListener('click', () => fileInput.click());

        // ── Drag events ─────────────────────────────────────────
        dropZone.addEventListener('dragover', e => {
            e.preventDefault();
            dropZone.classList.add('dark:border-amber-500', 'border-amber-500', 'dark:bg-amber-500/5', 'bg-amber-500/5');
        });
        dropZone.addEventListener('dragleave', () => {
            dropZone.classList.remove('dark:border-amber-500', 'border-amber-500', 'dark:bg-amber-500/5', 'bg-amber-500/5');
        });
        dropZone.addEventListener('drop', e => {
            e.preventDefault();
            dropZone.classList.remove('dark:border-amber-500', 'border-amber-500', 'dark:bg-amber-500/5', 'bg-amber-500/5');
            handleFiles(Array.from(e.dataTransfer.files));
        });

        // ── File input change ────────────────────────────────────
        fileInput.addEventListener('change', e => {
            handleFiles(Array.from(e.target.files));
            fileInput.value = ''; // reset so same file can be re-added after removal
        });

        // ── Validate + merge files ───────────────────────────────
        function handleFiles(incoming) {
            const errors = [];

            const valid = incoming.filter(f => {
                const ext = '.' + f.name.split('.').pop().toLowerCase();
                if (!ACCEPTED_EXT.includes(ext)) {
                    errors.push(`<strong>${f.name}</strong> — unsupported format (${ext})`);
                    return false;
                }
                if (f.size > MAX_SIZE_B) {
                    errors.push(`<strong>${f.name}</strong> — exceeds 5 MB limit (${(f.size / 1024 / 1024).toFixed(1)} MB)`);
                    return false;
                }
                return true;
            });

            // Deduplicate by name
            const existing = new Set(selectedFiles.map(f => f.name));
            const fresh = valid.filter(f => !existing.has(f.name));

            // Check combined count
            const combined = selectedFiles.length + fresh.length;
            if (combined > MAX_FILES) {
                const overflow = combined - MAX_FILES;
                errors.push(`Too many files — removed ${overflow} file${overflow > 1 ? 's' : ''} to stay within the 10-file limit.`);
                fresh.splice(fresh.length - overflow, overflow);
            }

            selectedFiles = [...selectedFiles, ...fresh];

            showErrors(errors);
            renderPreview();
            syncSubmit();
        }

        // ── Render file preview list ─────────────────────────────
        function renderPreview() {
            if (selectedFiles.length === 0) {
                filePreview.classList.add('hidden');
                fileList.innerHTML = '';
                return;
            }
            filePreview.classList.remove('hidden');
            fileCount.textContent = selectedFiles.length;
            fileList.innerHTML = '';

            selectedFiles.forEach((f, i) => {
                const ext = '.' + f.name.split('.').pop().toLowerCase();
                const sizeFmt = f.size < 1024 * 1024
                    ? (f.size / 1024).toFixed(1) + ' KB'
                    : (f.size / 1024 / 1024).toFixed(1) + ' MB';

                const row = document.createElement('div');
                row.className = 'flex items-center gap-3 px-3 py-2.5 rounded-xl dark:bg-stone-900 bg-stone-100 border dark:border-stone-800 border-stone-200 group';
                row.innerHTML = `
        <div class="w-7 h-7 rounded-lg shrink-0 flex items-center justify-center ${iconBg(ext)}">
          ${iconSvg(ext)}
        </div>
        <div class="flex-1 min-w-0">
          <p class="font-mono text-xs dark:text-stone-200 text-stone-700 truncate">${f.name}</p>
          <p class="font-mono text-[10px] dark:text-stone-600 text-stone-400">${sizeFmt}</p>
        </div>
        <span class="font-mono text-[10px] px-2 py-0.5 rounded-md ${badgeCls(ext)}">${ext}</span>
        <button type="button" onclick="removeFile(${i})"
          class="p-1 rounded-lg opacity-0 group-hover:opacity-100 dark:hover:bg-stone-800 hover:bg-stone-200
            dark:text-stone-600 text-stone-400 dark:hover:text-red-400 hover:text-red-400 transition-all">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>`;
                fileList.appendChild(row);
            });
        }

        // ── Remove single file ────────────────────────────────────
        window.removeFile = function (index) {
            selectedFiles.splice(index, 1);
            renderPreview();
            syncSubmit();
            if (selectedFiles.length === 0) hideErrors();
        };

        // ── Clear all ─────────────────────────────────────────────
        window.clearFiles = function () {
            selectedFiles = [];
            renderPreview();
            syncSubmit();
            hideErrors();
        };

        // ── Folder path input → breadcrumb preview ────────────────
        folderInput.addEventListener('input', function () {
            const val = this.value.trim().replace(/^\/+|\/+$/g, '');
            if (!val) {
                pathPreview.classList.add('hidden');
                pathPreview.innerHTML = '';
                return;
            }
            const parts = val.split('/').filter(Boolean);
            pathPreview.classList.remove('hidden');
            pathPreview.innerHTML = parts.map((p, i) => `
      <span class="font-mono text-[11px] dark:text-stone-300 text-stone-600">${p}</span>
      ${i < parts.length - 1
                    ? '<svg class="w-3 h-3 dark:text-stone-600 text-stone-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>'
                    : ''}
    `).join('');
        });

        // ── Quick-select existing folder ──────────────────────────
        window.selectFolder = function (path) {
            folderInput.value = path;
            folderInput.dispatchEvent(new Event('input'));
        };

        // ── Enable / disable submit ───────────────────────────────
        function syncSubmit() {
            submitBtn.disabled = selectedFiles.length === 0;
        }

        // ── Error helpers ─────────────────────────────────────────
        function showErrors(errs) {
            if (!errs.length) return;
            errorBox.classList.remove('hidden');
            errorText.innerHTML = errs.map(e => `<div>• ${e}</div>`).join('');
        }
        function hideErrors() {
            errorBox.classList.add('hidden');
            errorText.innerHTML = '';
        }

        // ── Form submit — attach selectedFiles to input ───────────
        document.getElementById('upload-form').addEventListener('submit', function (e) {
            if (selectedFiles.length === 0) {e.preventDefault(); return;}

            // Build a fresh DataTransfer to attach our curated list
            const dt = new DataTransfer();
            selectedFiles.forEach(f => dt.items.add(f));
            fileInput.files = dt.files;
        });

        // ── Close modal ───────────────────────────────────────────
        window.closeUploadModal = function () {
            document.getElementById('upload-modal').classList.add('hidden');
            clearFiles();
            hideErrors();
            folderInput.value = '';
            pathPreview.classList.add('hidden');
        };

        // ── Icon helpers ──────────────────────────────────────────
        function iconBg(ext) {
            const map = {
                '.pdf': 'bg-red-500/10',
                '.doc': 'bg-sky-500/10', '.docx': 'bg-sky-500/10',
                '.xls': 'bg-emerald-500/10',
                '.zip': 'bg-yellow-500/10',
                '.png': 'bg-purple-500/10', '.jpg': 'bg-purple-500/10', '.jpeg': 'bg-purple-500/10',
            };
            return map[ext] || 'bg-amber-500/10';
        }

        function iconSvg(ext) {
            const color = {
                '.pdf': 'text-red-400',
                '.doc': 'text-sky-400', '.docx': 'text-sky-400',
                '.xls': 'text-emerald-400',
                '.zip': 'text-yellow-400',
                '.png': 'text-purple-400', '.jpg': 'text-purple-400', '.jpeg': 'text-purple-400',
            }[ext] || 'text-amber-400';

            const paths = {
                '.png': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>`,
                '.pdf': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M9 13h1.5a1 1 0 000-2H9v4m0-2h1.5M14 11v4m0-4h1a1 1 0 010 2h-1"/>`,
                '.zip': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/>`,
                '.xls': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M9 11l2 2-2 2m4-4l-2 2 2 2"/>`,
            };

            const docPath = `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M9 13l1.5 4 1.5-4 1.5 4 1.5-4"/>`;
            const defaultPath = `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>`;

            const p = paths[ext] || (['.doc', '.docx'].includes(ext) ? docPath : defaultPath);
            return `<svg class="w-4 h-4 ${color}" fill="none" stroke="currentColor" viewBox="0 0 24 24">${p}</svg>`;
        }

        function badgeCls(ext) {
            const map = {
                '.pdf': 'bg-red-500/10 text-red-400',
                '.doc': 'bg-sky-500/10 text-sky-400', '.docx': 'bg-sky-500/10 text-sky-400',
                '.xls': 'bg-emerald-500/10 text-emerald-400',
                '.zip': 'bg-yellow-500/10 text-yellow-400',
                '.png': 'bg-purple-500/10 text-purple-400',
                '.jpg': 'bg-purple-500/10 text-purple-400',
                '.jpeg': 'bg-purple-500/10 text-purple-400',
            };
            return map[ext] || 'bg-amber-500/10 text-amber-400';
        }

    })();
</script>
