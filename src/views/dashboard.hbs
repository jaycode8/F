{{> topbar
pageTitle="Dashboard"
pageSubtitle="Good to have you back"
onlineDevices=onlineDevices
totalFiles=totalFiles
storageUsed=storageUsed
storageTotal=storageTotal
storagePercent=storagePercent
unreadNotifications=unreadNotifications
userInitial=userInitial
userName=userName
userEmail=userEmail
userRole=userRole
}}

<div class="px-6 py-6 space-y-8 max-w-6xl mx-auto">
    <div>
        <h2 class="font-display font-extrabold text-2xl dark:text-white text-stone-900">
            Hey, {{userName}} 👋
        </h2>
        <p class="font-mono text-sm dark:text-stone-500 text-stone-400 mt-1">
            Here's what's happening on your network today.
        </p>
    </div>
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        <div class="dark:bg-obsidian-950 bg-white rounded-2xl border dark:border-stone-800 border-stone-200 p-5">
            <div class="flex items-start justify-between mb-4">
                <div class="w-9 h-9 rounded-xl bg-amber-500/15 flex items-center justify-center">
                    <svg class="w-4.5 h-4.5 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                    </svg>
                </div>
                <span
                    class="font-mono text-[10px] dark:text-stone-600 text-stone-400 bg-stone-100 dark:bg-stone-900 px-2 py-1 rounded-lg">total</span>
            </div>
            <p class="font-display font-extrabold text-2xl dark:text-white text-stone-900">{{totalFiles}}</p>
            <p class="font-mono text-xs dark:text-stone-500 text-stone-400 mt-1">Files stored</p>
        </div>
        <div class="dark:bg-obsidian-950 bg-white rounded-2xl border dark:border-stone-800 border-stone-200 p-5">
            <div class="flex items-start justify-between mb-4">
                <div class="w-9 h-9 rounded-xl bg-amber-500/15 flex items-center justify-center">
                    <svg class="w-4.5 h-4.5 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M4 7v10c0 2 1 3 3 3h10c2 0 3-1 3-3V9a2 2 0 00-2-2h-6l-2-2H7a2 2 0 00-3 2z" />
                    </svg>
                </div>
                <span
                    class="font-mono text-[10px] dark:text-stone-600 text-stone-400 bg-stone-100 dark:bg-stone-900 px-2 py-1 rounded-lg">storage</span>
            </div>
            <p class="font-display font-extrabold text-2xl dark:text-white text-stone-900">{{storageUsed}}</p>
            <p class="font-mono text-xs dark:text-stone-500 text-stone-400 mt-1">of {{storageTotal}} used</p>
            <div class="mt-3 h-1 rounded-full dark:bg-stone-800 bg-stone-100 overflow-hidden">
                <div class="h-full rounded-full bg-amber-500" style="width: {{storagePercent}}%"></div>
            </div>
        </div>
        <div class="dark:bg-obsidian-950 bg-white rounded-2xl border dark:border-stone-800 border-stone-200 p-5">
            <div class="flex items-start justify-between mb-4">
                <div class="w-9 h-9 rounded-xl bg-emerald-500/10 flex items-center justify-center">
                    <svg class="w-4.5 h-4.5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" />
                    </svg>
                </div>
                <span
                    class="font-mono text-[10px] dark:text-stone-600 text-stone-400 bg-stone-100 dark:bg-stone-900 px-2 py-1 rounded-lg">shared</span>
            </div>
            <p class="font-display font-extrabold text-2xl dark:text-white text-stone-900">{{sharedFiles}}</p>
            <p class="font-mono text-xs dark:text-stone-500 text-stone-400 mt-1">Shared with network</p>
        </div>
        <div class="dark:bg-obsidian-950 bg-white rounded-2xl border dark:border-stone-800 border-stone-200 p-5">
            <div class="flex items-start justify-between mb-4">
                <div class="w-9 h-9 rounded-xl bg-sky-500/10 flex items-center justify-center">
                    <svg class="w-4.5 h-4.5 text-sky-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                    </svg>
                </div>
                <span
                    class="font-mono text-[10px] dark:text-stone-600 text-stone-400 bg-stone-100 dark:bg-stone-900 px-2 py-1 rounded-lg">network</span>
            </div>
            <p class="font-display font-extrabold text-2xl dark:text-white text-stone-900">{{onlineDevices}}</p>
            <p class="font-mono text-xs dark:text-stone-500 text-stone-400 mt-1">Devices online</p>
        </div>
    </div>
    <div>
        <div class="flex items-center justify-between mb-4">
            <div>
                <h3 class="font-display font-bold text-lg dark:text-white text-stone-900">Recent Files</h3>
                <p class="font-mono text-xs dark:text-stone-500 text-stone-400 mt-0.5">Last uploaded across all types
                </p>
            </div>
            <a href="/files" class="flex items-center gap-2 px-4 py-2 rounded-xl font-mono text-xs
          dark:bg-stone-900 bg-stone-100
          dark:border-stone-800 border-stone-200 border
          dark:text-amber-400 text-amber-600
          dark:hover:bg-stone-800 hover:bg-stone-200
          transition-colors duration-150">
                View all files
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
            </a>
        </div>

        <div
            class="dark:bg-obsidian-950 bg-white rounded-2xl border dark:border-stone-800 border-stone-200 overflow-hidden">
            <div class="grid grid-cols-12 gap-4 px-5 py-3 border-b dark:border-stone-800 border-stone-100">
                <div
                    class="col-span-5 font-mono text-[11px] uppercase tracking-widest dark:text-stone-600 text-stone-400">
                    Name</div>
                <div
                    class="col-span-2 font-mono text-[11px] uppercase tracking-widest dark:text-stone-600 text-stone-400">
                    Type</div>
                <div
                    class="col-span-2 font-mono text-[11px] uppercase tracking-widest dark:text-stone-600 text-stone-400">
                    Size</div>
                <div
                    class="col-span-2 font-mono text-[11px] uppercase tracking-widest dark:text-stone-600 text-stone-400">
                    Uploaded</div>
                <div class="col-span-1"></div>
            </div>

            {{#each recentFiles}}
            <div
                class="grid grid-cols-12 gap-4 px-5 py-3.5 border-b dark:border-stone-800/50 border-stone-100 last:border-0 dark:hover:bg-stone-900/50 hover:bg-stone-50 transition-colors duration-100 group">

                <div class="col-span-5 flex items-center gap-3 min-w-0">
                    <div
                        class="w-8 h-8 rounded-lg shrink-0 flex items-center justify-center
            {{#if (eq this.type 'image')}}bg-purple-500/10{{else if (eq this.type 'video')}}bg-rose-500/10{{else if (eq this.type 'audio')}}bg-sky-500/10{{else if (eq this.type 'pdf')}}bg-red-500/10{{else if (eq this.type 'archive')}}bg-yellow-500/10{{else}}bg-amber-500/10{{/if}}">
                        {{#if (eq this.type 'image')}}
                        <svg class="w-4 h-4 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                        </svg>
                        {{else if (eq this.type 'video')}}
                        <svg class="w-4 h-4 text-rose-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M15 10l4.553-2.276A1 1 0 0121 8.723v6.554a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
                        </svg>
                        {{else if (eq this.type 'audio')}}
                        <svg class="w-4 h-4 text-sky-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3" />
                        </svg>
                        {{else if (eq this.type 'pdf')}}
                        <svg class="w-4 h-4 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
                        </svg>
                        {{else if (eq this.type 'archive')}}
                        <svg class="w-4 h-4 text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4" />
                        </svg>
                        {{else}}
                        <svg class="w-4 h-4 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                        </svg>
                        {{/if}}
                    </div>
                    <div class="min-w-0">
                        <p class="font-mono text-xs dark:text-stone-200 text-stone-700 truncate">{{this.name}}</p>
                        <p class="font-mono text-[10px] dark:text-stone-600 text-stone-400 truncate">{{this.uploadedBy}}
                        </p>
                    </div>
                </div>

                <div class="col-span-2 flex items-center">
                    <span
                        class="font-mono text-[10px] uppercase px-2 py-1 rounded-md
            {{#if (eq this.type 'image')}}bg-purple-500/10 text-purple-400{{else if (eq this.type 'video')}}bg-rose-500/10 text-rose-400{{else if (eq this.type 'audio')}}bg-sky-500/10 text-sky-400{{else if (eq this.type 'pdf')}}bg-red-500/10 text-red-400{{else if (eq this.type 'archive')}}bg-yellow-500/10 text-yellow-400{{else}}bg-amber-500/10 text-amber-400{{/if}}">
                        {{this.type}}
                    </span>
                </div>

                <div class="col-span-2 flex items-center">
                    <span class="font-mono text-xs dark:text-stone-500 text-stone-400">{{this.size}}</span>
                </div>

                <div class="col-span-2 flex items-center">
                    <span class="font-mono text-xs dark:text-stone-500 text-stone-400">{{this.uploadedAt}}</span>
                </div>

                <div
                    class="col-span-1 flex items-center justify-end gap-1 opacity-0 group-hover:opacity-100 transition-opacity duration-150">
                    <a href="/files/{{this.id}}/download"
                        class="p-1.5 rounded-lg dark:hover:bg-stone-800 hover:bg-stone-100 dark:text-stone-500 text-stone-400 dark:hover:text-amber-400 hover:text-amber-500 transition-colors">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                        </svg>
                    </a>
                    <a href="/files/{{this.id}}"
                        class="p-1.5 rounded-lg dark:hover:bg-stone-800 hover:bg-stone-100 dark:text-stone-500 text-stone-400 dark:hover:text-stone-200 hover:text-stone-600 transition-colors">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                        </svg>
                    </a>
                </div>
            </div>
            {{else}}
            <div class="flex flex-col items-center justify-center py-16 px-4 text-center">
                <div
                    class="w-14 h-14 rounded-2xl dark:bg-stone-900 bg-stone-50 border dark:border-stone-800 border-stone-200 flex items-center justify-center mb-4">
                    <svg class="w-6 h-6 dark:text-stone-700 text-stone-300" fill="none" stroke="currentColor"
                        viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                    </svg>
                </div>
                <p class="font-display font-bold dark:text-stone-500 text-stone-400 mb-1">No files yet</p>
                <p class="font-mono text-xs dark:text-stone-600 text-stone-400 mb-4">Upload your first file to get
                    started</p>
                <a href="/files"
                    class="flex items-center gap-2 px-4 py-2 rounded-xl bg-amber-500 hover:bg-amber-400 text-obsidian-950 font-mono text-xs transition-colors">
                    Go to Files
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                </a>
            </div>
            {{/each}}
        </div>
    </div>
</div>
