{{> topbar
pageTitle=folderName
pageSubtitle="Folder contents"
onlineDevices=onlineDevices
totalFiles=totalFiles
storageUsed=storageUsed
storageTotal=storageTotal
storagePercent=storagePercent
unreadNotifications=unreadNotifications
userInitial=userInitial
userName=userName
userEmail=userEmail
userRole=userRole
}}

<div class="px-6 py-6 space-y-6 max-w-6xl mx-auto">

    <!-- ── Breadcrumb ── -->
    <div class="flex items-center gap-2 font-mono text-xs">
        <a href="/files"
            class="dark:text-stone-500 text-stone-400 dark:hover:text-amber-400 hover:text-amber-500 transition-colors">Files</a>
        <svg class="w-3 h-3 dark:text-stone-700 text-stone-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
        <span class="dark:text-stone-300 text-stone-600">{{folderName}}</span>
    </div>

    <!-- ── Toolbar ── -->
    <div class="flex items-center gap-3 flex-wrap">
        <!-- Folder info -->
        <div class="flex items-center gap-3 flex-1">
            <div
                class="w-10 h-10 rounded-xl bg-{{folderColor}}-500/15 border border-{{folderColor}}-500/20 flex items-center justify-center">
                <svg class="w-5 h-5 text-{{folderColor}}-400" fill="currentColor" viewBox="0 0 24 24">
                    <path
                        d="M3 7a2 2 0 012-2h4.586a1 1 0 01.707.293L12 7h7a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V7z" />
                </svg>
            </div>
            <div>
                <p class="font-display font-bold dark:text-white text-stone-900 text-sm">{{folderName}}</p>
                <p class="font-mono text-[11px] dark:text-stone-500 text-stone-400">{{fileCount}} files · {{folderSize}}
                </p>
            </div>
        </div>

        <!-- Search inside folder -->
        <div class="relative">
            <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 w-4 h-4 dark:text-stone-600 text-stone-400 pointer-events-none"
                fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <input type="text" id="file-search" placeholder="Search files…" class="pl-10 pr-4 py-2.5 rounded-xl text-sm font-mono w-56
          dark:bg-obsidian-950 bg-white
          dark:border-stone-800 border-stone-200 border
          dark:text-stone-300 text-stone-700
          dark:placeholder-stone-600 placeholder-stone-400
          focus:outline-none focus:border-amber-500 focus:ring-2 focus:ring-amber-500/20
          transition-all duration-200" />
        </div>

        <!-- Upload into this folder -->
        <button onclick="document.getElementById('upload-modal').classList.remove('hidden')" class="flex items-center gap-2 px-4 py-2.5 rounded-xl font-mono text-xs
        bg-amber-500 hover:bg-amber-400 text-obsidian-950 font-bold
        shadow-lg shadow-amber-500/20 active:scale-95 transition-all duration-150">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
            </svg>
            Upload Here
        </button>
    </div>

    <!-- ── Files table ── -->
    {{#if files.length}}
    <div
        class="dark:bg-obsidian-950 bg-white rounded-2xl border dark:border-stone-800 border-stone-200 overflow-hidden">
        <!-- Header -->
        <div class="grid grid-cols-12 gap-4 px-5 py-3 border-b dark:border-stone-800 border-stone-100">
            <div class="col-span-5 font-mono text-[11px] uppercase tracking-widest dark:text-stone-600 text-stone-400">
                Name</div>
            <div class="col-span-2 font-mono text-[11px] uppercase tracking-widest dark:text-stone-600 text-stone-400">
                Type</div>
            <div class="col-span-2 font-mono text-[11px] uppercase tracking-widest dark:text-stone-600 text-stone-400">
                Size</div>
            <div class="col-span-2 font-mono text-[11px] uppercase tracking-widest dark:text-stone-600 text-stone-400">
                Uploaded</div>
            <div class="col-span-1"></div>
        </div>
        <!-- Rows -->
        <div id="file-list">
            {{#each files}}
            {{> file-row this}}
            {{/each}}
        </div>
    </div>
    {{else}}
    <!-- Empty folder -->
    <div
        class="flex flex-col items-center justify-center py-24 dark:bg-obsidian-950 bg-white rounded-2xl border dark:border-stone-800 border-stone-200 text-center">
        <div
            class="w-14 h-14 rounded-2xl bg-{{folderColor}}-500/10 border border-{{folderColor}}-500/20 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-{{folderColor}}-400" fill="currentColor" viewBox="0 0 24 24">
                <path d="M3 7a2 2 0 012-2h4.586a1 1 0 01.707.293L12 7h7a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V7z" />
            </svg>
        </div>
        <p class="font-display font-bold dark:text-stone-500 text-stone-400 mb-1">This folder is empty</p>
        <p class="font-mono text-xs dark:text-stone-600 text-stone-400 mb-5">Upload files to get started</p>
        <button onclick="document.getElementById('upload-modal').classList.remove('hidden')"
            class="flex items-center gap-2 px-4 py-2.5 rounded-xl bg-amber-500 hover:bg-amber-400 text-obsidian-950 font-mono text-xs font-bold transition-all">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
            </svg>
            Upload Files
        </button>
    </div>
    {{/if}}

</div>

<!-- ── Upload Modal ── -->
<div id="upload-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
    <div class="absolute inset-0 dark:bg-black/70 bg-black/40 backdrop-blur-sm"
        onclick="document.getElementById('upload-modal').classList.add('hidden')"></div>
    <div
        class="relative w-full max-w-lg dark:bg-obsidian-950 bg-white rounded-2xl border dark:border-stone-800 border-stone-200 p-6 shadow-2xl">
        <div class="flex items-center justify-between mb-5">
            <div>
                <h2 class="font-display font-bold text-lg dark:text-white text-stone-900">Upload to {{folderName}}</h2>
                <p class="font-mono text-xs dark:text-stone-500 text-stone-400 mt-0.5">Files will be added to this
                    folder</p>
            </div>
            <button onclick="document.getElementById('upload-modal').classList.add('hidden')"
                class="p-1.5 rounded-lg dark:hover:bg-stone-800 hover:bg-stone-100 dark:text-stone-500 text-stone-400 transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
        </div>
        <form action="/files/folder/{{folderId}}/upload" method="POST" enctype="multipart/form-data">
            <div id="drop-zone2" class="rounded-xl p-10 text-center cursor-pointer dark:bg-stone-900/60 bg-stone-50 mb-4
          border-2 border-dashed dark:border-stone-800 border-stone-200
          dark:hover:border-amber-500 hover:border-amber-500
          dark:hover:bg-amber-500/5 hover:bg-amber-500/5
          transition-all duration-200">
                <div
                    class="w-12 h-12 rounded-xl bg-amber-500/15 border border-amber-500/30 flex items-center justify-center mx-auto mb-3">
                    <svg class="w-6 h-6 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
                    </svg>
                </div>
                <p class="font-display font-bold dark:text-stone-300 text-stone-600 mb-1">Drop files here</p>
                <p class="font-mono text-xs dark:text-stone-600 text-stone-400">or click to browse</p>
                <input type="file" id="file-input2" name="files" multiple class="hidden" />
            </div>
            <div id="file-preview2" class="space-y-2 mb-4 max-h-40 overflow-y-auto hidden"></div>
            <button type="submit"
                class="w-full py-3 rounded-xl bg-amber-500 hover:bg-amber-400 text-obsidian-950 font-display font-bold text-sm transition-all active:scale-95">
                Upload
            </button>
        </form>
    </div>
</div>

<script>
    // Live search within folder
    document.getElementById('file-search').addEventListener('input', function () {
        const q = this.value.toLowerCase();
        document.querySelectorAll('#file-list > div').forEach(row => {
            const name = row.querySelector('a')?.textContent?.toLowerCase() || '';
            row.style.display = name.includes(q) ? '' : 'none';
        });
    });

    // Drop zone
    const dz = document.getElementById('drop-zone2');
    const fi = document.getElementById('file-input2');
    if (dz && fi) {
        dz.addEventListener('click', () => fi.click());
        dz.addEventListener('dragover', e => {e.preventDefault(); dz.classList.add('border-amber-500');});
        dz.addEventListener('dragleave', () => dz.classList.remove('border-amber-500'));
        dz.addEventListener('drop', e => {e.preventDefault(); dz.classList.remove('border-amber-500'); handleFiles2(e.dataTransfer.files);});
        fi.addEventListener('change', e => handleFiles2(e.target.files));
    }

    function handleFiles2(files) {
        const preview = document.getElementById('file-preview2');
        preview.classList.remove('hidden');
        preview.innerHTML = '';
        Array.from(files).forEach(f => {
            const el = document.createElement('div');
            el.className = 'flex items-center gap-3 px-3 py-2 rounded-lg dark:bg-stone-800 bg-stone-100';
            el.innerHTML = `
        <svg class="w-4 h-4 text-amber-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        <span class="font-mono text-xs truncate dark:text-stone-300 text-stone-600">${f.name}</span>
        <span class="font-mono text-[10px] dark:text-stone-600 text-stone-400 ml-auto shrink-0">${(f.size / 1024).toFixed(1)} KB</span>`;
            preview.appendChild(el);
        });
    }
</script>
