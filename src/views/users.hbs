{{> topbar}}

<div class="px-6 py-6 space-y-6 max-w-5xl mx-auto">

    <!-- ── Toolbar ── -->
    <div class="flex items-center gap-3 flex-wrap">

        <!-- Search -->
        <form method="GET" action="/users" class="relative flex-1 min-w-48 flex items-center gap-2">
            <div class="relative flex-1">
                <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 w-4 h-4 dark:text-stone-600 text-stone-400 pointer-events-none"
                    fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
                <input type="text" name="search" placeholder="Search by username or email…" value="{{currentSearch}}"
                    class="w-full pl-10 pr-4 py-2.5 rounded-xl text-sm font-mono
            dark:bg-obsidian-950 bg-white
            dark:border-stone-800 border-stone-200 border
            dark:text-stone-300 text-stone-700
            dark:placeholder-stone-600 placeholder-stone-400
            focus:outline-none focus:border-amber-500 focus:ring-2 focus:ring-amber-500/20
            transition-all duration-200" />
            </div>
            <button type="submit" class="px-4 py-2.5 rounded-xl font-mono text-xs
          dark:bg-stone-900 bg-stone-100 border dark:border-stone-800 border-stone-200
          dark:text-stone-300 text-stone-600
          dark:hover:border-amber-500/50 hover:border-amber-500/50
          transition-all duration-150">
                Search
            </button>
            {{#if currentSearch}}
            <a href="/users" class="px-4 py-2.5 rounded-xl font-mono text-xs
          dark:bg-stone-900 bg-stone-100 border dark:border-stone-800 border-stone-200
          dark:text-red-400 text-red-400
          dark:hover:border-red-500/50 hover:border-red-500/50
          transition-all duration-150">
                Clear
            </a>
            {{/if}}
        </form>

        <!-- Invite user -->
        <button onclick="document.getElementById('invite-modal').classList.remove('hidden')" class="flex items-center gap-2 px-4 py-2.5 rounded-xl font-mono text-xs
        bg-amber-500 hover:bg-amber-400 text-obsidian-950 font-bold
        shadow-lg shadow-amber-500/20 active:scale-95
        transition-all duration-150">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" />
            </svg>
            Add User
        </button>
    </div>

    <!-- ── Results count ── -->
    {{#if userData.results.length}}
    <div class="flex items-center justify-between">
        <p class="font-mono text-xs dark:text-stone-500 text-stone-400">
            <span class="dark:text-stone-300 text-stone-600">{{userData.count}}</span>
            user{{#unless (eq userData.count 1)}}s{{/unless}}
            {{#if currentSearch}}
            matching <span class="dark:text-amber-400 text-amber-600">"{{currentSearch}}"</span>
            {{/if}}
        </p>
    </div>
    {{/if}}

    <!-- ── Users table ── -->
    {{#if userData.results.length}}
    <div
        class="dark:bg-obsidian-950 bg-white rounded-2xl border dark:border-stone-800 border-stone-200 overflow-hidden">

        <!-- Header -->
        <div class="grid grid-cols-12 gap-4 px-5 py-3 border-b dark:border-stone-800 border-stone-100">
            <div class="col-span-4 font-mono text-[11px] uppercase tracking-widest dark:text-stone-600 text-stone-400">
                User</div>
            <div class="col-span-2 font-mono text-[11px] uppercase tracking-widest dark:text-stone-600 text-stone-400">
                Role</div>
            <div class="col-span-3 font-mono text-[11px] uppercase tracking-widest dark:text-stone-600 text-stone-400">
                Storage</div>
            <div class="col-span-2 font-mono text-[11px] uppercase tracking-widest dark:text-stone-600 text-stone-400">
                Last login</div>
            <div class="col-span-1"></div>
        </div>

        <!-- Rows -->
        {{#each userData.results}}
        <div class="grid grid-cols-12 gap-4 px-5 py-4
      border-b dark:border-stone-800/50 border-stone-100 last:border-0
      dark:hover:bg-stone-900/50 hover:bg-stone-50
      transition-colors duration-100 group">

            <!-- Avatar + name + email -->
            <div class="col-span-4 flex items-center gap-3 min-w-0">
                <div class="w-9 h-9 rounded-xl shrink-0
          bg-amber-500/20 border border-amber-500/30
          flex items-center justify-center
          font-display font-bold text-sm text-amber-400">
                    {{initial this.username}}
                </div>
                <div class="min-w-0">
                    <p class="font-mono text-xs dark:text-stone-200 text-stone-700 truncate font-medium">
                        {{this.username}}
                    </p>
                    <p class="font-mono text-[10px] dark:text-stone-600 text-stone-400 truncate">
                        {{this.email}}
                    </p>
                </div>
            </div>

            <!-- Role badge -->
            <div class="col-span-2 flex items-center">
                <span class="font-mono text-[10px] px-2 py-1 rounded-md
          {{#if (eq this.role 'admin')}}
            bg-amber-500/15 text-amber-400
          {{else}}
            bg-stone-500/10 dark:text-stone-400 text-stone-500
          {{/if}}">
                    {{this.role}}
                </span>
            </div>

            <!-- Storage bar -->
            <div class="col-span-3 flex flex-col justify-center gap-1">
                <div class="flex items-center justify-between">
                    <span class="font-mono text-[10px] dark:text-stone-400 text-stone-500">
                        {{formatSize this.storageUsed}}
                    </span>
                    <span class="font-mono text-[10px] dark:text-stone-600 text-stone-400">
                        / {{formatSize this.storageLimit}}
                    </span>
                </div>
                <div class="h-1 rounded-full dark:bg-stone-800 bg-stone-200 overflow-hidden">
                    <div class="h-full rounded-full transition-all duration-500
            {{#if (gte (storagePercent this.storageUsed this.storageLimit) 90)}}
              bg-red-400
            {{else if (gte (storagePercent this.storageUsed this.storageLimit) 70)}}
              bg-amber-400
            {{else}}
              bg-emerald-400
            {{/if}}" style="width: {{storagePercent this.storageUsed this.storageLimit}}%">
                    </div>
                </div>
            </div>

            <!-- Last login -->
            <div class="col-span-2 flex items-center">
                {{#if this.lastLogin}}
                <span class="font-mono text-xs dark:text-stone-500 text-stone-400">
                    {{formatDate this.lastLogin}}
                </span>
                {{else}}
                <span class="font-mono text-xs dark:text-stone-600 text-stone-400">Never</span>
                {{/if}}
            </div>

            <!-- Actions -->
            <div
                class="col-span-1 flex items-center justify-end gap-1 opacity-0 group-hover:opacity-100 transition-opacity duration-150">
                <button onclick="openDeleteUser('{{this._id}}', '{{this.username}}')" title="Delete user" class="p-1.5 rounded-lg dark:hover:bg-stone-800 hover:bg-stone-100
            dark:text-stone-500 text-stone-400
            dark:hover:text-red-400 hover:text-red-400
            transition-colors">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                    </svg>
                </button>
            </div>
        </div>
        {{/each}}
    </div>

    <!-- ── Pagination ── -->
    {{#if (gt userData.total_pages 1)}}
    <div class="flex items-center justify-center gap-2">
        {{#if userData.previous}}
        <a href="?page={{prev userData.page}}{{#if currentSearch}}&search={{currentSearch}}{{/if}}" class="flex items-center gap-1.5 px-4 py-2 rounded-xl font-mono text-xs
        dark:bg-stone-900 bg-white border dark:border-stone-800 border-stone-200
        dark:text-stone-400 text-stone-600
        dark:hover:border-amber-500/50 hover:border-amber-500/50
        transition-all duration-150">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
            Previous
        </a>
        {{/if}}

        {{#times userData.total_pages}}
        <a href="?page={{this}}{{#if ../currentSearch}}&search={{../currentSearch}}{{/if}}" class="w-9 h-9 rounded-xl font-mono text-xs flex items-center justify-center border transition-all duration-150
        {{#if (eq this ../userData.page)}}
          bg-amber-500 border-amber-500 text-obsidian-950 font-bold
        {{else}}
          dark:bg-stone-900 bg-white dark:border-stone-800 border-stone-200
          dark:text-stone-400 text-stone-600
          dark:hover:border-amber-500/50 hover:border-amber-500/50
        {{/if}}">
            {{this}}
        </a>
        {{/times}}

        {{#if userData.next}}
        <a href="?page={{next userData.page}}{{#if currentSearch}}&search={{currentSearch}}{{/if}}" class="flex items-center gap-1.5 px-4 py-2 rounded-xl font-mono text-xs
        dark:bg-stone-900 bg-white border dark:border-stone-800 border-stone-200
        dark:text-stone-400 text-stone-600
        dark:hover:border-amber-500/50 hover:border-amber-500/50
        transition-all duration-150">
            Next
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
        </a>
        {{/if}}
    </div>
    {{/if}}

    {{else}}

    <!-- ── Empty state ── -->
    <div class="flex flex-col items-center justify-center py-24 text-center">
        <div
            class="w-16 h-16 rounded-2xl dark:bg-stone-900 bg-stone-50 border dark:border-stone-800 border-stone-200 flex items-center justify-center mb-5">
            {{#if currentSearch}}
            <svg class="w-7 h-7 dark:text-stone-700 text-stone-300" fill="none" stroke="currentColor"
                viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            {{else}}
            <svg class="w-7 h-7 dark:text-stone-700 text-stone-300" fill="none" stroke="currentColor"
                viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            {{/if}}
        </div>
        {{#if currentSearch}}
        <p class="font-display font-bold text-lg dark:text-stone-500 text-stone-400 mb-1">No users found</p>
        <p class="font-mono text-xs dark:text-stone-600 text-stone-400 mb-6">Nothing matched "{{currentSearch}}"</p>
        <a href="/users" class="px-4 py-2.5 rounded-xl font-mono text-xs
        dark:bg-stone-900 bg-stone-100 border dark:border-stone-800 border-stone-200
        dark:text-stone-300 text-stone-600 transition-colors">
            Clear search
        </a>
        {{else}}
        <p class="font-display font-bold text-lg dark:text-stone-500 text-stone-400 mb-1">No users yet</p>
        <p class="font-mono text-xs dark:text-stone-600 text-stone-400 mb-6">Add the first user to get started</p>
        <button onclick="document.getElementById('invite-modal').classList.remove('hidden')" class="flex items-center gap-2 px-4 py-2.5 rounded-xl font-mono text-xs
        bg-amber-500 hover:bg-amber-400 text-obsidian-950 font-bold transition-all">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" />
            </svg>
            Add User
        </button>
        {{/if}}
    </div>
    {{/if}}

</div>

<!-- ── Add User Modal ── -->
<div id="invite-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
    <div class="absolute inset-0 dark:bg-black/70 bg-black/40 backdrop-blur-sm"
        onclick="document.getElementById('invite-modal').classList.add('hidden')"></div>

    <div
        class="relative w-full max-w-sm dark:bg-obsidian-950 bg-white rounded-2xl border dark:border-stone-800 border-stone-200 shadow-2xl overflow-hidden">

        <!-- Header -->
        <div class="flex items-center justify-between px-6 pt-6 pb-4 border-b dark:border-stone-800 border-stone-100">
            <div>
                <h2 class="font-display font-bold text-lg dark:text-white text-stone-900">Add User</h2>
                <p class="font-mono text-[11px] dark:text-stone-500 text-stone-400 mt-0.5">New users are assigned the
                    user role</p>
            </div>
            <button onclick="document.getElementById('invite-modal').classList.add('hidden')"
                class="p-1.5 rounded-lg dark:hover:bg-stone-800 hover:bg-stone-100 dark:text-stone-500 text-stone-400 transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
        </div>

        <div class="px-6 py-5 space-y-4">

            <!-- Username -->
            <div>
                <label
                    class="block font-mono text-[11px] uppercase tracking-widest dark:text-stone-500 text-stone-400 mb-2">
                    Username
                </label>
                <div class="relative">
                    <span class="absolute left-3.5 top-1/2 -translate-y-1/2 pointer-events-none">
                        <svg class="w-4 h-4 dark:text-stone-600 text-stone-400" fill="none" stroke="currentColor"
                            viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                        </svg>
                    </span>
                    <input type="text" id="new-username" placeholder="johndoe" class="w-full pl-10 pr-4 py-3 rounded-xl text-sm font-mono
              dark:bg-stone-900 bg-stone-50
              dark:border-stone-800 border-stone-200 border
              dark:text-stone-200 text-stone-800
              dark:placeholder-stone-700 placeholder-stone-400
              focus:outline-none focus:border-amber-500 focus:ring-2 focus:ring-amber-500/20
              transition-all duration-200" />
                </div>
            </div>

            <!-- Email -->
            <div>
                <label
                    class="block font-mono text-[11px] uppercase tracking-widest dark:text-stone-500 text-stone-400 mb-2">
                    Email
                </label>
                <div class="relative">
                    <span class="absolute left-3.5 top-1/2 -translate-y-1/2 pointer-events-none">
                        <svg class="w-4 h-4 dark:text-stone-600 text-stone-400" fill="none" stroke="currentColor"
                            viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                        </svg>
                    </span>
                    <input type="email" id="new-email" placeholder="john@example.com" class="w-full pl-10 pr-4 py-3 rounded-xl text-sm font-mono
              dark:bg-stone-900 bg-stone-50
              dark:border-stone-800 border-stone-200 border
              dark:text-stone-200 text-stone-800
              dark:placeholder-stone-700 placeholder-stone-400
              focus:outline-none focus:border-amber-500 focus:ring-2 focus:ring-amber-500/20
              transition-all duration-200" />
                </div>
            </div>

            <!-- Password -->
            <div>
                <label
                    class="block font-mono text-[11px] uppercase tracking-widest dark:text-stone-500 text-stone-400 mb-2">
                    Password
                </label>
                <div class="relative">
                    <span class="absolute left-3.5 top-1/2 -translate-y-1/2 pointer-events-none">
                        <svg class="w-4 h-4 dark:text-stone-600 text-stone-400" fill="none" stroke="currentColor"
                            viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                        </svg>
                    </span>
                    <input type="password" id="new-password" placeholder="••••••••" class="w-full pl-10 pr-4 py-3 rounded-xl text-sm font-mono
              dark:bg-stone-900 bg-stone-50
              dark:border-stone-800 border-stone-200 border
              dark:text-stone-200 text-stone-800
              dark:placeholder-stone-600 placeholder-stone-400
              focus:outline-none focus:border-amber-500 focus:ring-2 focus:ring-amber-500/20
              transition-all duration-200" />
                </div>
            </div>

        </div>

        <!-- Footer -->
        <div class="px-6 py-4 border-t dark:border-stone-800 border-stone-100 flex items-center gap-3">
            <button type="button" onclick="document.getElementById('invite-modal').classList.add('hidden')" class="flex-1 py-3 rounded-xl font-mono text-xs
          dark:bg-stone-900 bg-stone-100
          dark:border-stone-800 border-stone-200 border
          dark:text-stone-400 text-stone-600
          dark:hover:bg-stone-800 hover:bg-stone-200
          transition-all duration-150">
                Cancel
            </button>
            <button type="button" onclick="submitAddUser()" class="flex-1 py-3 rounded-xl font-display font-bold text-sm
          bg-amber-500 hover:bg-amber-400 text-obsidian-950
          shadow-lg shadow-amber-500/20 active:scale-95
          transition-all duration-150">
                Add User
            </button>
        </div>
    </div>
</div>

<script>
    // ── Add user ──────────────────────────────────────────────────
    async function submitAddUser() {
        const username = document.getElementById('new-username').value.trim();
        const email = document.getElementById('new-email').value.trim();
        const password = document.getElementById('new-password').value;

        if (!username || !email || !password) {
            toast.warning('All fields are required');
            return;
        }

        document.getElementById('invite-modal').classList.add('hidden');
        const toastId = toast.loading('Creating user…');

        try {
            const res = await fetch('/users', {
                method: 'POST',
                credentials: 'include',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({username, email, password}),
            });
            const data = await res.json();

            if (res.ok) {
                toast.resolve(toastId, 'success', data.message || 'User created successfully');
                setTimeout(() => window.location.reload(), 900);
            } else {
                toast.resolve(toastId, 'error', data.detail || 'Failed to create user');
            }
        } catch {
            toast.resolve(toastId, 'error', 'Connection error. Please try again.');
        }
    }

    // ── Delete user ───────────────────────────────────────────────
    async function openDeleteUser(id, username) {
        const ok = await confirm({
            type: 'danger',
            title: 'Delete user?',
            message: 'This will permanently remove the user and all their data.',
            detail: username,
            okLabel: 'Delete permanently',
        });
        if (!ok) return;

        const toastId = toast.loading('Deleting user…');
        try {
            const res = await fetch(`/users/${id}`, {
                method: 'DELETE',
                credentials: 'include',
            });
            const data = await res.json();

            if (res.ok) {
                toast.resolve(toastId, 'success', data.message || 'User deleted successfully');
                setTimeout(() => window.location.reload(), 900);
            } else {
                toast.resolve(toastId, 'error', data.detail || 'Failed to delete user');
            }
        } catch {
            toast.resolve(toastId, 'error', 'Connection error. Please try again.');
        }
    }
</script>
