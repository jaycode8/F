<div class="min-h-dvh flex">
    <div class="hidden lg:flex lg:w-[60%] 2xl:w-3/4 relative overflow-hidden">
        <img src="https://images.unsplash.com/photo-1558494949-ef010cbdcc31?w=1800&q=80" alt="File network"
            class="absolute inset-0 w-full h-full object-cover" />
        <div class="absolute inset-0 dark:bg-obsidian-950/65 bg-white/30 transition-colors duration-300"></div>
        <div
            class="absolute inset-0 dark:bg-gradient-to-r dark:from-transparent dark:to-obsidian-950 bg-gradient-to-r from-transparent to-white transition-colors duration-300">
        </div>

        <div class="absolute top-10 left-10 flex items-center gap-3 z-10">
            <div class="w-9 h-9 rounded-xl bg-amber-500 flex items-center justify-center shadow-lg shadow-amber-500/30">
                <svg class="w-5 h-5 text-obsidian-950" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                        d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" />
                </svg>
            </div>
            <!-- <span class="font-display font-extrabold text-2xl dark:text-white text-stone-900 tracking-tight">F</span> -->
        </div>

        <div class="absolute bottom-10 left-10 right-10 z-10">
            <p class="font-display font-bold text-3xl dark:text-white text-stone-900 leading-snug mb-3">
                Your files.<br />Your network.<br /><span class="text-amber-500">Your control.</span>
            </p>
            <p class="font-mono text-sm dark:text-stone-400 text-stone-600 max-w-sm">
                Upload, share and access files across every device on your local network — fast, private, no cloud
                needed.
            </p>

            <div class="flex items-center gap-6 mt-8">
                <div class="flex items-center gap-2">
                    <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
                    <span class="font-mono text-xs dark:text-stone-400 text-stone-600">{{onlineDevices}} devices
                        online</span>
                </div>
                <div class="w-px h-4 dark:bg-stone-700 bg-stone-300"></div>
                <div class="font-mono text-xs dark:text-stone-400 text-stone-600">{{totalFiles}} files stored</div>
                <div class="w-px h-4 dark:bg-stone-700 bg-stone-300"></div>
                <div class="font-mono text-xs dark:text-stone-400 text-stone-600">{{storageUsed}} used</div>
            </div>
        </div>
    </div>

    <div class="w-full lg:w-[40%] 2xl:w-1/4 min-h-dvh flex flex-col justify-center px-10 py-12
    dark:bg-obsidian-950 bg-white relative">
        <div class="flex items-center gap-3 mb-10 lg:hidden">
            <div class="w-9 h-9 rounded-xl bg-amber-500 flex items-center justify-center shadow-lg shadow-amber-500/30">
                <svg class="w-5 h-5 text-obsidian-950" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                        d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" />
                </svg>
            </div>
            <span class="font-display font-extrabold text-2xl dark:text-white text-stone-900">F</span>
        </div>

        <div class="mb-8">
            <h2 class="font-displays font-extrabold text-3xl dark:text-white text-stone-900 mb-2">Welcome back</h2>
            <p class="text-sm dark:text-stone-500 text-stone-500 font-mono">Sign in to your F account</p>
        </div>

        {{#if error}}
        <div class="mb-6 flex items-center gap-3 px-4 py-3 rounded-xl bg-red-500/10 border border-red-500/30">
            <svg class="w-4 h-4 text-red-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <p class="text-sm text-red-400 font-mono">{{error}}</p>
        </div>
        {{/if}}

        <form action="/auth/signin" method="POST" class="space-y-5">
            <div>
                <label
                    class="block font-mono text-[11px] uppercase tracking-widest dark:text-stone-500 text-stone-400 mb-2">
                    Username
                </label>
                <div class="relative">
                    <span class="absolute left-3.5 top-1/2 -translate-y-1/2 pointer-events-none">
                        <svg class="w-4 h-4 dark:text-stone-600 text-stone-400" fill="none" stroke="currentColor"
                            viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                        </svg>
                    </span>
                    <input type="text" name="username" autocomplete="username" placeholder="doejane"
                        value="{{username}}"
                        class="w-full pl-10 pr-4 py-3 rounded-xl text-sm font-mono dark:bg-stone-900 bg-stone-50 dark:border-stone-800 border-stone-200 border dark:text-stone-200 text-stone-800 dark:placeholder-stone-700 placeholder-stone-400 focus:outline-none focus:border-amber-500 focus:ring-2 focus:ring-amber-500/70 transition-all duration-200"
                        required />
                </div>
            </div>

            <div>
                <label
                    class="block font-mono text-[11px] uppercase tracking-widest dark:text-stone-500 text-stone-400 mb-2">
                    Password
                </label>
                <div class="relative">
                    <span class="absolute left-3.5 top-1/2 -translate-y-1/2 pointer-events-none">
                        <svg class="w-4 h-4 dark:text-stone-600 text-stone-400" fill="none" stroke="currentColor"
                            viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                        </svg>
                    </span>
                    <input type="password" id="password" name="password" autocomplete="current-password"
                        placeholder="••••••••"
                        class="w-full pl-10 pr-11 py-3 rounded-xl text-sm font-mono dark:bg-stone-900 bg-stone-50 dark:border-stone-800 border-stone-200 border dark:text-stone-200 text-stone-800 dark:placeholder-stone-600 placeholder-stone-400 focus:outline-none focus:border-amber-500 focus:ring-2 focus:ring-amber-500/70 transition-all duration-200"
                        required />
                    <button type="button" onclick="togglePassword()"
                        class="absolute right-3.5 top-1/2 -translate-y-1/2 dark:text-stone-600 text-stone-400 dark:hover:text-stone-300 hover:text-stone-600 transition-colors">
                        <svg id="eye-open" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                        </svg>
                        <svg id="eye-closed" class="w-4 h-4 hidden" fill="none" stroke="currentColor"
                            viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21" />
                        </svg>
                    </button>
                </div>
            </div>

            <label class="flex items-center gap-2.5 cursor-pointer w-fit">
                <input type="checkbox" name="remember" class="w-4 h-4 rounded border-2 dark:border-stone-700 border-stone-300 bg-transparent accent-amber-500
            focus:outline-none focus:ring-2 focus:ring-amber-500/20 transition-all duration-150" />
                <span class="font-mono text-xs dark:text-stone-500 text-stone-500">Remember me</span>
            </label>

            <button type="submit" class="w-full py-3.5 rounded-xl font-display font-bold text-sm text-obsidian-950
          bg-amber-500 hover:bg-amber-400 active:scale-95
          shadow-lg shadow-amber-500/20 hover:shadow-amber-400/30
          transition-all duration-150">
                Sign In
            </button>
        </form>

        <div class="absolute bottom-8 left-10 right-10 flex items-center justify-between">
            <div class="flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
                <span class="font-mono text-[11px] dark:text-stone-600 text-stone-400">Local network</span>
            </div>
            <button onclick="toggleTheme()"
                class="font-mono text-[11px] dark:text-stone-600 text-stone-400 dark:hover:text-stone-300 hover:text-stone-600 transition-colors flex items-center gap-1.5">
                <svg class="w-3.5 h-3.5 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z" />
                </svg>
                <svg class="w-3.5 h-3.5 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
                </svg>
                Toggle theme
            </button>
        </div>
    </div>
</div>

<script>
    function togglePassword() {
        const input = document.getElementById('password');
        const open = document.getElementById('eye-open');
        const closed = document.getElementById('eye-closed');
        if (input.type === 'password') {
            input.type = 'text';
            open.classList.add('hidden');
            closed.classList.remove('hidden');
        } else {
            input.type = 'password';
            open.classList.remove('hidden');
            closed.classList.add('hidden');
        }
    }
</script>
